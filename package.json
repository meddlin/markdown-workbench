{
  "name": "markdown-reflow",
  "displayName": "Markdown Reflow",
  "description": "Automatic and manual prose reflow for Markdown and MDX without touching code or MDX metadata blocks.",
  "version": "0.4.1",
  "publisher": "rushinglabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/meddlin/markdown-reflow.git"
  },
  "homepage": "https://github.com/meddlin/markdown-reflow#readme",
  "bugs": {
    "url": "https://github.com/meddlin/markdown-reflow/issues"
  },
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "markdown",
    "mdx",
    "wrap",
    "reflow",
    "formatting"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:mdx",
    "onCommand:markdownReflow.setMaxLineLength",
    "onCommand:markdownReflow.toggleMaxLineLengthIndicator",
    "onCommand:markdownReflow.setMaxLineLengthIndicatorColor",
    "onCommand:markdownReflow.reflow",
    "onCommand:markdownReflow.generateToc"
  ],
  "main": "./out/extension.js",
  "files": [
    "out",
    "icon.png",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SUPPORT.md",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "markdownReflow.reflow",
        "title": "Markdown Reflow: Reflow Prose"
      },
      {
        "command": "markdownReflow.setMaxLineLength",
        "title": "Markdown Reflow: Set Maximum Line Length"
      },
      {
        "command": "markdownReflow.toggleMaxLineLengthIndicator",
        "title": "Markdown Reflow: Toggle Maximum Line Length Indicator"
      },
      {
        "command": "markdownReflow.setMaxLineLengthIndicatorColor",
        "title": "Markdown Reflow: Set Maximum Line Length Indicator Color"
      },
      {
        "command": "markdownReflow.generateToc",
        "title": "Markdown Reflow: Generate Table of Contents"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "markdownReflow.reflow",
          "when": "editorLangId == markdown || editorLangId == mdx"
        },
        {
          "command": "markdownReflow.setMaxLineLength",
          "when": "editorLangId == markdown || editorLangId == mdx"
        },
        {
          "command": "markdownReflow.toggleMaxLineLengthIndicator",
          "when": "editorLangId == markdown || editorLangId == mdx"
        },
        {
          "command": "markdownReflow.setMaxLineLengthIndicatorColor",
          "when": "editorLangId == markdown || editorLangId == mdx"
        },
        {
          "command": "markdownReflow.generateToc",
          "when": "editorLangId == markdown || editorLangId == mdx"
        }
      ],
      "editor/title": [
        {
          "command": "markdownReflow.reflow",
          "when": "editorLangId == markdown || editorLangId == mdx",
          "group": "navigation"
        },
        {
          "command": "markdownReflow.generateToc",
          "when": "editorLangId == markdown || editorLangId == mdx",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "markdownReflow.reflow",
          "when": "editorLangId == markdown || editorLangId == mdx",
          "group": "1_modification"
        },
        {
          "command": "markdownReflow.generateToc",
          "when": "editorLangId == markdown || editorLangId == mdx",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Reflow",
      "properties": {
        "markdownReflow.maxLineLength": {
          "type": "number",
          "default": 100,
          "minimum": 20,
          "description": "Maximum line length for wrapped prose."
        },
        "markdownReflow.automaticReflow": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, automatically reflow prose while typing after edited lines exceed the maximum line length."
        },
        "markdownReflow.showMaxLineLengthIndicator": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, show an editor ruler at the configured maximum line length for Markdown Reflow languages."
        },
        "markdownReflow.maxLineLengthIndicatorColor": {
          "type": "string",
          "default": "light gray",
          "description": "Color for the maximum line length indicator. Use a supported common name such as light gray, blue, or red, or a hex color such as #888888."
        },
        "markdownReflow.languages": {
          "type": "array",
          "default": [
            "markdown",
            "mdx"
          ],
          "items": {
            "type": "string"
          },
          "description": "Language IDs this command is allowed to edit."
        },
        "markdownReflow.preserveListItems": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, leave Markdown list items and their continuation blocks unchanged."
        },
        "markdownReflow.selectionOnlyWhenSelected": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, only reflow paragraphs intersecting the current selection."
        }
      }
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\" && tsc -p ./tsconfig.json",
    "watch": "tsc -w -p ./tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
